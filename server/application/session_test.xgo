package application

import (
	"strings"
	"testing"
	"qiniu-ime/server/domain"
	"qiniu-ime/server/infrastructure/provider/mock"
	"qiniu-ime/server/infrastructure/storage"
	"qiniu-ime/server/ports"
)

func TestSessionEndAppliesMemoryAndPostprocess(t *testing.T) {
	store := storage.NewInMemoryStore()
	router := NewProviderRouter([]ports.ASRProvider{mock.NewProvider()})
	service := NewSessionService(router, store)
	session, err := service.Start(domain.ASRSessionConfig{
		Scene: "work",
		Provider: "mock",
		PostprocessMode: "light",
		MockText: "我们用扣豆上传文件",
	})
	if err != nil {
		t.Fatal(err)
	}
	_, err = session.SendAudio(domain.AudioChunk{Seq: 1, PCM: "AA=="})
	if err != nil {
		t.Fatal(err)
	}
	events, err := session.End()
	if err != nil {
		t.Fatal(err)
	}
	final := events[len(events)-1]
	if !strings.Contains(final.CorrectedText, "Kodo") {
		t.Fatalf("expected Kodo correction, got %#v", final)
	}
	if err := session.Close(); err != nil {
		t.Fatal(err)
	}
}
