package local

import (
	"encoding/base64"
	"os"
	"testing"
	"qiniu-ime/server/domain"
)

func TestLocalProviderUsesExplicitFixtureText(t *testing.T) {
	os.Setenv("QINIU_IME_LOCAL_ASR_TEXT", "我们用扣豆上传文件")
	defer os.Unsetenv("QINIU_IME_LOCAL_ASR_TEXT")

	provider := NewProvider()
	stream, err := provider.Start(domain.ASRSessionConfig{Provider: "local", Format: "webm"})
	if err != nil {
		t.Fatal(err)
	}
	events, err := stream.End()
	if err != nil {
		t.Fatal(err)
	}
	if events[0].RawText != "我们用扣豆上传文件" {
		t.Fatalf("unexpected local text: %s", events[0].RawText)
	}
}

func TestLocalProviderRejectsUnsupportedFormat(t *testing.T) {
	os.Setenv("QINIU_IME_LOCAL_ASR_TEXT", "x")
	defer os.Unsetenv("QINIU_IME_LOCAL_ASR_TEXT")

	_, err := NewProvider().Start(domain.ASRSessionConfig{Provider: "local", Format: "pcm16"})
	if err == nil {
		t.Fatal("expected format error")
	}
}

func TestLocalProviderPartialAndNoAudioError(t *testing.T) {
	os.Setenv("QINIU_IME_LOCAL_ASR_TEXT", "")
	defer os.Unsetenv("QINIU_IME_LOCAL_ASR_TEXT")

	stream, err := (&Provider{scriptPath: "provider_test.xgo", python: "cmd", model: "tiny"}).Start(domain.ASRSessionConfig{Provider: "local", Format: "webm"})
	if err != nil {
		t.Fatal(err)
	}
	partial, err := stream.SendAudio(domain.AudioChunk{Seq: 7, PCM: base64.StdEncoding.EncodeToString([]byte{0})})
	if err != nil {
		t.Fatal(err)
	}
	if partial[0].Text != "正在本地识别..." || partial[0].Seq != 7 {
		t.Fatalf("unexpected partial: %#v", partial[0])
	}
}

func TestLocalProviderTranscribeFailsFast(t *testing.T) {
	os.Setenv("QINIU_IME_LOCAL_ASR_TEXT", "")
	defer os.Unsetenv("QINIU_IME_LOCAL_ASR_TEXT")

	stream := &Stream{
		provider: &Provider{scriptPath: "provider_test.xgo", python: "cmd", model: "tiny"},
		chunks: []string{base64.StdEncoding.EncodeToString([]byte{0})},
	}
	if _, err := stream.End(); err == nil {
		t.Fatal("expected command error")
	}

	stream = &Stream{
		provider: &Provider{scriptPath: "provider_test.xgo", python: "cmd", model: "tiny"},
		chunks: []string{"not-base64"},
	}
	if _, err := stream.End(); err == nil {
		t.Fatal("expected decode error")
	}
}

func TestLocalProviderRequiresAudio(t *testing.T) {
	os.Setenv("QINIU_IME_LOCAL_ASR_TEXT", "")
	defer os.Unsetenv("QINIU_IME_LOCAL_ASR_TEXT")

	stream := &Stream{provider: &Provider{scriptPath: "provider_test.xgo", python: "cmd", model: "tiny"}}
	if _, err := stream.End(); err == nil {
		t.Fatal("expected no audio error")
	}
}
